### Get all blogs
GET http://localhost:3001/api/blogs

### Create a new blog
POST http://localhost:3001/api/blogs
Content-Type: application/json

{
  "author": "Dan Abramov",
  "url": "https://overreacted.io",
  "title": "My Decade in Review"
}

### Delete a blog (replace '1' with your actual blog ID)
DELETE http://localhost:3001/api/blogs/1

### Update the likes of a blog
PUT http://localhost:3001/api/blogs/2
Content-Type: application/json

{
  "likes": 50
}

### Create a new user
POST http://localhost:3001/api/users
Content-Type: application/json

{
  "username": "mluukkai@fso.com",
  "name": "Matti Luukkainen"
}

### Change a username
PUT http://localhost:3001/api/users/mluukkai@fso.com
Content-Type: application/json

{
  "username": "matti@fso.com"
}

### Get all users
GET http://localhost:3001/api/users

### Log in to get a token
POST http://localhost:3001/api/login
Content-Type: application/json

{
  "username": "matti@fso.com"
}

### Create a new blog with authentication
POST http://localhost:3001/api/blogs
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6Im1hdHRpQGZzby5jb20iLCJpZCI6MSwiaWF0IjoxNzgwOTI1OTU2fQ.-aVxLS7sblw_8lj3o4XrMCI9etNNQahC2UH70BmHqoA

{
  "author": "Dan Abramov",
  "url": "https://overreacted.io/why-lean-code-matters",
  "title": "Why Lean Code Matters"
}

### Attempt deleting blog 4 WITHOUT a token (Should return 401 Unauthorized)
DELETE http://localhost:3001/api/blogs/4

### Delete blog 4 WITH a valid token (Should return 204 No Content)
DELETE http://localhost:3001/api/blogs/4
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6Im1hdHRpQGZzby5jb20iLCJpZCI6MSwiaWF0IjoxNzgwOTI1OTU2fQ.-aVxLS7sblw_8lj3o4XrMCI9etNNQahC2UH70BmHqoA

### Add a blog to a user's reading list
POST http://localhost:3001/api/readinglists
Content-Type: application/json

{
  "blogId": 2,
  "userId": 1
}

### Get a specific user profile along with their reading list
GET http://localhost:3001/api/users/1

### Update reading list status (Mark as Read)
PUT http://localhost:3001/api/readinglists/1
Authorization: bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6Im1hdHRpQGZzby5jb20iLCJpZCI6MSwiaWF0IjoxNzgwOTI5ODcyfQ.RKsukZE4e5vn6-0rJjJIwMeK5rJ2zhOgIVI5NS1TJNw
Content-Type: application/json

{
  "read": true
}

### Get reading list filtered to show ONLY READ items
GET http://localhost:3001/api/users/1?read=true

### Get reading list filtered to show ONLY UNREAD items
GET http://localhost:3001/api/users/1?read=false

### Search blogs by a keyword matching title (e.g., 'Integration')
GET http://localhost:3001/api/blogs?search=Integration

### Search blogs by a keyword matching author (e.g., 'Martin')
GET http://localhost:3001/api/blogs?search=Martin

### Search blogs using lowercase matching to verify case-insensitivity (e.g., 'fowler')
GET http://localhost:3001/api/blogs?search=fowler
### Create a blog with active session
POST http://localhost:3001/api/blogs
Content-Type: application/json
Authorization: Bearer <YOUR_TOKEN_HERE>

{
  "title": "Stateful Sessions are Awesome",
  "author": "Matti",
  "url": "https://fso.com/stateful",
  "likes": 10
}
### Destroy the session
DELETE http://localhost:3001/api/logout
Authorization: Bearer <YOUR_TOKEN_HERE>