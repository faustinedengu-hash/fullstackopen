FROM node:22-alpine

WORKDIR /usr/src/app

# Copy package files first for caching benefits
COPY package*.json ./

# Install all dependencies (including nodemon)
RUN npm install

# Copy the rest of the backend source code
COPY . .

# Expose the backend API port (matching your app setup)
EXPOSE 3003

# Run nodemon with the Legacy Watch flag (-L) so file changes trigger restarts inside the container
CMD ["npm", "run", "dev", "--", "-L"]